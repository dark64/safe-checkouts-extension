{
  "name": "Safe Checkouts",
  "description": "Indicates if a website’s checkout form is legitimate",
  "version": "0.0.1",
  "manifest_version": 3,
  "permissions": ["storage"],
  "content_scripts": [
    {
      "js": ["extension.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "safe-checkouts@githamcity.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
